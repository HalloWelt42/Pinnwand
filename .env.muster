# Pinnwand - Konfigurationsvorlage. Kopiere diese Datei zu .env und passe sie an.
# Nur Platzhalter, niemals echte Geheimnisse oder Produktivdaten committen.
#
# Wichtig: Alle KI- und Integrationsdienste sind OPTIONAL. Ohne sie laeuft Pinnwand
# voll funktionsfaehig; die betroffenen Funktionen werden dann dezent ausgeblendet.

# --- Server ---
PINNWAND_BIND=127.0.0.1
PINNWAND_BACKEND_PORT=8420
PINNWAND_FRONTEND_PORT=5198

# --- Optional: LLM und Embeddings (OpenAI-kompatibel, z.B. lokaler Modell-Host) ---
# Leer lassen, um LLM-Funktionen abzuschalten.
PINNWAND_LLM_URL=
PINNWAND_EMBEDDING_MODEL=

# --- Optional: Vektor-DB fuer die semantische Suche ---
PINNWAND_QDRANT_URL=

# --- Vorlesen (TTS, pappagei) ---
# Standard ist der lokale pappagei-Dienst. Laeuft er, wird er automatisch genutzt;
# sonst greift die Browser-Sprachausgabe. Zum Abweichen hier eine andere URL setzen.
PINNWAND_TTS_URL=http://127.0.0.1:8765

# --- Transkriptionen (txt2voice) ---
# Standard ist der lokale txt2voice-Dienst; laeuft er, erscheinen die Transkripte.
PINNWAND_TRANSCRIPTS_URL=http://localhost:10031

# --- Optional: Spracheingabe / Whisper (Mikrofon) ---
PINNWAND_STT_URL=

# --- Agenten-API ---
# Token koennen in der Oberflaeche verwaltet werden. Optionales Vorab-Token:
PINNWAND_AGENT_TOKEN=
# MCP-Server unter /mcp aktivieren (optional, nur lokal empfohlen): 1 = an
PINNWAND_MCP=
